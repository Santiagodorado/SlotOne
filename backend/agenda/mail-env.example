# Plantilla correo — micro `agenda` (copiá a .env o mail.env; no subas secretos al repo).

# Opción: misma carpeta que run-local.ps1 → .env (prioridad) o mail.env

SLOTONE_MAIL_ENABLED=true

SLOTONE_MAIL_BUSINESS_TO=

# =============================================================================
# Producción SOLO plan gratuito (Render): SMTP bloqueado → usá Resend (HTTPS)
# =============================================================================
# 1) https://resend.com — API key y (ideal) dominio verificado.
# 2) SLOTONE_MAIL_FROM = dirección que Resend permita (p. ej. onboarding@resend.dev
#    en pruebas, o noreply@tudominio.com si verificaste el dominio).
# 3) RESEND_API_KEY=re_...
# 4) Opcional: que al responder le llegue a tu Gmail del equipo:
SLOTONE_MAIL_REPLY_TO=hola.slotone@gmail.com

# Ejemplo Resend (ajustá "from" según tu cuenta Resend):
# SLOTONE_MAIL_FROM=SlotOne <onboarding@resend.dev>
# RESEND_API_KEY=re_xxxxxxxx

# No hace falta definir SMTP_* en Render free para enviar (se ignoran si hay RESEND_API_KEY).

# =============================================================================
# Solo en tu PC (desarrollo): Gmail por SMTP — funciona en local
# =============================================================================
# SLOTONE_MAIL_FROM=hola.slotone@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=hola.slotone@gmail.com
# SMTP_PASSWORD=<contraseña de aplicación de Google, 16 caracteres>
# SMTP_AUTH=true
# SMTP_STARTTLS=true
# En local: NO pongas RESEND_API_KEY si querés probar solo Gmail por SMTP.

# Local sin Gmail (Mailpit, etc.):
# SMTP_HOST=localhost SMTP_PORT=1025 SMTP_AUTH=false SMTP_STARTTLS=false
