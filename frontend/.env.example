# URL base del API. En desarrollo no hace falta: Vite reenvía /api al gateway (localhost:8080).
#
# Producción (Vercel): URL pública del gateway en Render. Puede ser con o sin "/api" al final;
# el cliente asegura el sufijo /api. Ejemplos válidos:
# VITE_API_URL=https://tu-gateway.onrender.com
# VITE_API_URL=https://tu-gateway.onrender.com/api
